rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: varieties
    // Document ID: auto-generated
    // Fields:
    //   - uid: string (required) - Owner's user ID
    //   - name: string (required) - Variety name
    //   - species: string (optional)
    //   - breeder: string (optional)
    //   - site: string (optional)
    //   - flowering_date: string (optional)
    //   - maturity_date: string (optional)
    //   - precocity: string (optional)
    //   - fruit_size: number (optional)
    //   - color: string (optional)
    //   - bloom: string (optional)
    //   - fruit_shape: string (optional)
    //   - brix: number (optional)
    //   - firmness: string (optional)
    //   - acidity: string (optional)
    //   - aroma: string (optional)
    //   - vigor: string (optional)
    //   - habit: string (optional)
    //   - yield_estimate: number (optional)
    //   - sensitivities: string (optional)
    //   - free_notes: string (optional)
    //   - photos: string (optional) - JSON string
    //   - ai_analysis: string (optional) - JSON string
    //   - createdAt: number (optional)
    //   - updatedAt: number (optional)
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    function isValidOptionalString(field, maxLen) {
      return !(field in request.resource.data) || 
             (request.resource.data[field] is string && request.resource.data[field].size() <= maxLen);
    }
    function isValidOptionalNumber(field) {
      return !(field in request.resource.data) || (request.resource.data[field] is number);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidVariety() {
      return hasRequiredFields(['uid', 'name']) &&
             request.resource.data.uid is string &&
             request.resource.data.name is string && request.resource.data.name.size() > 0 && request.resource.data.name.size() < 100 &&
             isValidOptionalString('species', 100) &&
             isValidOptionalString('breeder', 100) &&
             isValidOptionalString('site', 100) &&
             isValidOptionalString('flowering_date', 50) &&
             isValidOptionalString('maturity_date', 50) &&
             isValidOptionalString('precocity', 50) &&
             isValidOptionalNumber('fruit_size') &&
             isValidOptionalString('color', 50) &&
             isValidOptionalString('bloom', 50) &&
             isValidOptionalString('fruit_shape', 50) &&
             isValidOptionalNumber('brix') &&
             isValidOptionalString('firmness', 50) &&
             isValidOptionalString('acidity', 50) &&
             isValidOptionalString('aroma', 200) &&
             isValidOptionalString('vigor', 50) &&
             isValidOptionalString('habit', 50) &&
             isValidOptionalNumber('yield_estimate') &&
             isValidOptionalString('sensitivities', 500) &&
             isValidOptionalString('free_notes', 2000) &&
             isValidOptionalString('photos', 1048576) && // 1MB max for JSON string
             isValidOptionalString('ai_analysis', 1048576) &&
             isValidOptionalNumber('createdAt') &&
             isValidOptionalNumber('updatedAt');
    }

    match /varieties/{varietyId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && uidUnchanged() && isValidVariety();
      allow update: if isDocOwner() && uidNotModified() && isValidVariety();
      allow delete: if isDocOwner();
    }
  }
}
