{
  "entities": {
    "Variety": {
      "title": "Variety",
      "description": "A blueberry variety record with agronomic and organoleptic data.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user ID of the owner."
        },
        "name": {
          "type": "string",
          "description": "Name of the variety."
        },
        "species": {
          "type": "string"
        },
        "breeder": {
          "type": "string"
        },
        "site": {
          "type": "string"
        },
        "flowering_date": {
          "type": "string"
        },
        "maturity_date": {
          "type": "string"
        },
        "precocity": {
          "type": "string"
        },
        "fruit_size": {
          "type": "number"
        },
        "color": {
          "type": "string"
        },
        "bloom": {
          "type": "string"
        },
        "fruit_shape": {
          "type": "string"
        },
        "brix": {
          "type": "number"
        },
        "firmness": {
          "type": "string"
        },
        "acidity": {
          "type": "string"
        },
        "aroma": {
          "type": "string"
        },
        "vigor": {
          "type": "string"
        },
        "habit": {
          "type": "string"
        },
        "yield_estimate": {
          "type": "number"
        },
        "sensitivities": {
          "type": "string"
        },
        "free_notes": {
          "type": "string"
        },
        "photos": {
          "type": "string",
          "description": "JSON stringified array of photo objects due to Firestore nested array limitations, or just an array if simple enough. We will use a JSON string to be safe with complex objects."
        },
        "ai_analysis": {
          "type": "string",
          "description": "JSON stringified AI analysis result."
        },
        "createdAt": {
          "type": "number"
        },
        "updatedAt": {
          "type": "number"
        }
      },
      "required": ["uid", "name"]
    }
  },
  "firestore": {
    "varieties/{varietyId}": {
      "schema": {
        "$ref": "#/entities/Variety"
      },
      "description": "Stores blueberry varieties."
    }
  }
}
